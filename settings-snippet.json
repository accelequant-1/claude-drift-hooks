{
  "_comment": "TEMPLATE — install.sh replaces these with absolute paths. Do NOT copy this file directly into settings.local.json. Run install.sh instead.",
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash __HOOK_DIR__/drift-metric.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash(git commit*)",
        "hooks": [
          {
            "type": "command",
            "command": "bash __HOOK_DIR__/git-commit-gate.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash(git push*)",
        "hooks": [
          {
            "type": "command",
            "command": "bash __HOOK_DIR__/git-push-gate.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
